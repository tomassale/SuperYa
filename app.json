{
  "expo": {
    "name": "SuperYa",
    "slug": "app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/img/IconApp.png",
    "scheme": "app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/img/adaptive-icon.png",
        "backgroundColor": "#A2A498"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.tomas.dev.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/img/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/img/Icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#A2A498"
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bbcbea75-9515-4cc9-b56d-7e1e80495308"
      }
    }
  }
}
